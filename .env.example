# Django Settings
# ===============

# Required: Secret key for Django (generate a new one for production)
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (set to False in production)
DJANGO_DEBUG=True

# Allowed hosts (comma-separated list)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Log level
DJANGO_LOG_LEVEL=INFO

# Database Settings (External MySQL)
# ==================================

# External MySQL database connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=money_journey
MYSQL_USER=money_journey_user
MYSQL_PASSWORD=strong-password-here

# Security Settings
# =================

# CSRF and Session security (set to True in production)
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=False

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# SSL/TLS settings (set to True in production)
SECURE_SSL_REDIRECT=False

# Superuser Creation (Optional)
# =============================
# Uncomment and set these to create a superuser on first deploy
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpassword

# Email Settings (Optional)
# =========================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# Application Settings
# ====================
# Login redirect
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/

# Development Database (for docker-compose.yml)
# =============================================
# These are used by the MySQL container in development
MYSQL_ROOT_PASSWORD=root_password